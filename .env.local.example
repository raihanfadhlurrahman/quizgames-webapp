# Copy this file to .env.local and fill the values. DO NOT commit your real keys.

# Public (client) keys for Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_or_publishable_key>

# Service role key (USE ONLY for local seeding or server-side operations).
# Never commit this key to source control.
SUPABASE_SERVICE_ROLE_KEY=<service_role_key_for_local_use_only>

# After creating .env.local, restart the Next.js dev server:
# npm run dev
# or
# pnpm dev
